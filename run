#!/usr/bin/env bash
# picture-sort wrapper: keeps the CLI a single, short command regardless of
# the caller's working directory. Resolves the repo root from this script's
# location, then runs the local Python entry point through uv without
# attempting to refresh the lockfile.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v uv >/dev/null 2>&1; then
  echo "picture-sort: 'uv' not found in PATH" >&2
  exit 127
fi

exec uv run --no-sync --project "$SCRIPT_DIR" python "$SCRIPT_DIR/main.py" "$@"
